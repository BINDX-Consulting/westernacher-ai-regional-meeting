];

var ROUND_TOPICS = [
  {
    label: 'Round 1 — Yesterday / Today / Blockers',
    prompt: 'Give your standup update for the Phoenix S/4HANA project. What did you accomplish yesterday? What are you working on today? What blockers do you have? Be specific to your role and the current project situation.'
  },
  {
    label: 'Round 2 — Risk Discussion',
    prompt: 'The Scrum Master has flagged that the go-live is at risk due to the data migration delay and open critical defects. React from your role\'s perspective. What is your assessment of the risk? What do you recommend? Reference the previous discussion.'
  },
  {
    label: 'Round 3 — Action Items & Close',
    prompt: 'Based on everything discussed, what are your specific action items for today? Be concrete with owners and deadlines. Then the Scrum Master should close the meeting with a brief summary of the 3 most critical actions agreed.'
  }
];

var state = {
  running: false,
  round: 0,
  messages: [],
  done: false
};

function setAgentState(id, st) {
  var card = document.getElementById('card-'+id);
  var dot  = document.getElementById('dot-'+id);
  var stEl = document.getElementById('status-'+id);
  card.className = 'agent-card' + (st==='speaking'?' speaking':st==='thinking'?' thinking':'');
  dot.className  = 'agent-dot dot-' + (st||'idle');
  var labels = {idle:'Idle',thinking:'Thinking…',speaking:'Speaking',done:'Done'};
  stEl.textContent = labels[st] || 'Idle';
  stEl.style.color = st==='speaking'?'#1A7A3C':st==='thinking'?'#A0600A':st==='done'?'#1A7A3C':'#A8C0D6';
}

function addRoundDivider(label) {
  var empty = document.getElementById('emptyRoom');
  if (empty) empty.remove();
  var feed = document.getElementById('chatFeed');
  var div = document.createElement('div');
  div.className = 'round-divider';
  div.innerHTML = '<div class="rd-line"></div><div class="rd-label">'+label+'</div><div class="rd-line"></div>';
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function showTyping(agent) {
  var empty = document.getElementById('emptyRoom');
  if (empty) empty.remove();
  var feed = document.getElementById('chatFeed');
  var div = document.createElement('div');
  div.className = 'typing-msg';
  div.id = 'typing-'+agent.id;
  div.innerHTML =
    '<div class="msg-avatar" style="background:'+agent.tagBg+'">'+agent.emoji+'</div>'+
    '<div><div class="msg-header"><span class="msg-name">'+agent.name+'</span><span class="msg-role-tag" style="background:'+agent.tagBg+';color:'+agent.tagColor+'">'+agent.role+'</span></div>'+
    '<div class="typing-bubble"><span></span><span></span><span></span></div></div>';
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function removeTyping(agentId) {
  var t = document.getElementById('typing-'+agentId);
  if (t) t.remove();
}

function addMessage(agent, text) {
  var feed = document.getElementById('chatFeed');
  var now = new Date();
  var time = now.getHours()+':'+(now.getMinutes()<10?'0':'')+now.getMinutes();
  var div = document.createElement('div');
  div.className = 'message';
  var html = text.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  div.innerHTML =
    '<div class="msg-avatar" style="background:'+agent.tagBg+'">'+agent.emoji+'</div>'+
    '<div class="msg-body">'+
      '<div class="msg-header">'+
        '<span class="msg-name">'+agent.name+'</span>'+
        '<span class="msg-role-tag" style="background:'+agent.tagBg+';color:'+agent.tagColor+'">'+agent.role+'</span>'+
        '<span class="msg-time">'+time+'</span>'+
      '</div>'+
      '<div class="msg-bubble">'+html+'</div>'+
    '</div>';
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

async function callAgent(agent, userPrompt) {
  var messages = state.messages.slice(-8).concat([{role:'user', content: userPrompt}]);
  var resp = await fetch(PROXY, {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 300,
      system: agent.system,
      messages: messages
    })
  });
  if (!resp.ok) throw new Error('API '+resp.status);
  var data = await resp.json();
  return data.content[0].text;
}

async function runRound(roundIndex) {
  var topic = ROUND_TOPICS[roundIndex];
  addRoundDivider(topic.label);
  document.getElementById('roundBadge').textContent = 'Round '+(roundIndex+1)+' / 3';

  for (var i = 0; i < AGENTS.length; i++) {
    if (!state.running) return;
    var agent = AGENTS[i];
    setAgentState(agent.id, 'thinking');
    showTyping(agent);

    var conversationContext = state.messages.length > 0
      ? 'Previous discussion in this meeting:\n' + state.messages.slice(-6).map(function(m){return m.role+': '+m.content;}).join('\n') + '\n\nNow: '
      : '';

    try {
      var reply = await callAgent(agent, conversationContext + topic.prompt);
      removeTyping(agent.id);
      setAgentState(agent.id, 'speaking');
      addMessage(agent, reply);
      state.messages.push({role:'user', content:agent.name+' ('+agent.role+'): '+reply});
      await sleep(800);
      setAgentState(agent.id, 'done');
    } catch(e) {
      removeTyping(agent.id);
      setAgentState(agent.id, 'idle');
      addMessage(agent, '[Connection issue — skipping this turn]');
    }
    await sleep(400);
  }
}

function sleep(ms) { return new Promise(function(r){setTimeout(r,ms);}); }

async function startMeeting() {
  if (state.running) return;
  state.running = true;
  state.round = 0;
  document.getElementById('startBtn').disabled = true;
  document.getElementById('startBtn').textContent = '⏳ Meeting in progress…';
  document.getElementById('statusBadge').className = 'status-badge status-running';
  document.getElementById('statusBadge').textContent = '🟢 Live';

  try {
    for (var r = 0; r < ROUND_TOPICS.length; r++) {
      if (!state.running) break;
      state.round = r;
      document.getElementById('roundInfo').textContent = 'Round '+(r+1)+' of '+ROUND_TOPICS.length;
      await runRound(r);
      if (r < ROUND_TOPICS.length - 1) await sleep(1200);
    }
  } catch(e) {
    showToast('Error: ' + e.message);
  }

  // Meeting done
  state.running = false;
  state.done = true;
  AGENTS.forEach(function(a){ setAgentState(a.id, 'idle'); });
  document.getElementById('statusBadge').className = 'status-badge status-done';
  document.getElementById('statusBadge').textContent = '✅ Meeting Complete';
  document.getElementById('startBtn').disabled = false;
  document.getElementById('startBtn').textContent = '▶ Run Again';
  document.getElementById('roundBadge').textContent = 'Complete ✓';
  showToast('Scrum meeting complete! 3 rounds done.');
}

function resetMeeting() {
  state.running = false;
  state.round = 0;
  state.messages = [];
  state.done = false;
  AGENTS.forEach(function(a){ setAgentState(a.id, 'idle'); });
  document.getElementById('chatFeed').innerHTML =
    '<div class="empty-room" id="emptyRoom">'+
    '<div class="er-icon">🤝</div>'+
    '<h3>Meeting room is empty.</h3>'+
    '<p>Press Start to watch 5 AI agents run a real SAP project scrum — powered live by Claude.</p>'+
    '</div>';
  document.getElementById('startBtn').disabled = false;
  document.getElementById('startBtn').textContent = '▶ Start Scrum Meeting';
  document.getElementById('statusBadge').className = 'status-badge status-idle';
  document.getElementById('statusBadge').textContent = '⚡ Ready';
  document.getElementById('roundBadge').textContent = 'Round 0 / 3';
  document.getElementById('roundInfo').textContent = '5 agents · 3 rounds';
}

function showToast(m) {
  var t = document.getElementById('toast');
  t.textContent = m; t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 3000);
}
</script>
