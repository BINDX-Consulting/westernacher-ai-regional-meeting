<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Agents — Scrum Meeting</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; overflow:hidden; }
body { font-family: Arial, 'Helvetica Neue', sans-serif; background:#F5F7FA; color:#0D1B2A; }

header { position:fixed; top:0; left:0; right:0; height:54px; display:flex; align-items:center; justify-content:space-between; padding:0 2rem; background:#FFFFFF; border-bottom:2px solid #1A5F8A; z-index:100; }
.h-left { display:flex; align-items:center; gap:14px; }
.h-div { width:1px; height:18px; background:#C5D5E4; }
.h-title { font-family:'Arial Black',Arial,sans-serif; font-size:15px; font-weight:900; color:#0D3D5C; }
.h-sub { font-size:11px; color:#4A6A82; margin-top:1px; }
.h-right { display:flex; align-items:center; gap:10px; }
.status-badge { font-size:11px; padding:4px 12px; border-radius:20px; font-weight:700; }
.status-idle { background:#E8F2FA; color:#1A5F8A; border:1px solid #C5D5E4; }
.status-running { background:#E8F5ED; color:#1A7A3C; border:1px solid #A8D5B8; animation:pulse-badge 1.5s infinite; }
.status-done { background:#F0EEF8; color:#5B4B8A; border:1px solid #C5B8E8; }
@keyframes pulse-badge { 0%,100%{opacity:1} 50%{opacity:0.7} }

.layout { display:grid; grid-template-columns:260px 1fr; height:100vh; padding-top:54px; }

/* AGENTS SIDEBAR */
.agents-panel { border-right:1px solid #C5D5E4; background:#F0F4F8; display:flex; flex-direction:column; overflow:hidden; }
.agents-header { padding:1rem 1.3rem; border-bottom:1px solid #C5D5E4; background:#FFFFFF; }
.agents-label { font-size:10px; font-weight:700; letter-spacing:1.5px; color:#1A5F8A; text-transform:uppercase; margin-bottom:0.8rem; }
.sprint-info { background:#E8F2FA; border-radius:8px; padding:10px 12px; border:1px solid #C5D5E4; }
.sprint-title { font-size:12px; font-weight:700; color:#0D3D5C; margin-bottom:3px; }
.sprint-sub { font-size:10.5px; color:#4A6A82; line-height:1.4; }

.agents-list { padding:1rem 1.3rem; display:flex; flex-direction:column; gap:8px; overflow-y:auto; flex:1; }
.agent-card { background:#FFFFFF; border:1px solid #C5D5E4; border-radius:10px; padding:12px; transition:all 0.3s; }
.agent-card.speaking { border-color:#1A5F8A; box-shadow:0 0 0 3px rgba(26,95,138,0.12); background:#F0F6FB; }
.agent-card.thinking { border-color:#A0600A; box-shadow:0 0 0 2px rgba(160,96,10,0.1); }
.agent-top { display:flex; align-items:center; gap:10px; margin-bottom:6px; }
.agent-avatar { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.agent-name { font-size:13px; font-weight:700; color:#0D1B2A; }
.agent-role { font-size:10px; color:#4A6A82; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
.agent-status { font-size:10px; margin-top:4px; display:flex; align-items:center; gap:5px; }
.agent-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.dot-idle { background:#C5D5E4; }
.dot-thinking { background:#A0600A; animation:blink 0.8s infinite; }
.dot-speaking { background:#1A7A3C; animation:blink 0.6s infinite; }
.dot-done { background:#1A7A3C; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.controls { padding:1rem 1.3rem; border-top:1px solid #C5D5E4; background:#FFFFFF; display:flex; flex-direction:column; gap:8px; }
.start-btn { width:100%; padding:12px; background:#1A5F8A; border:none; border-radius:8px; font-family:'Arial Black',Arial,sans-serif; font-size:13px; font-weight:900; color:#FFFFFF; cursor:pointer; transition:all 0.2s; }
.start-btn:hover { background:#0D3D5C; transform:translateY(-1px); }
.start-btn:disabled { background:#C5D5E4; color:#7A95A8; cursor:not-allowed; transform:none; }
.reset-btn { width:100%; padding:9px; background:#FFFFFF; border:1px solid #C5D5E4; border-radius:8px; font-size:12px; font-weight:700; color:#4A6A82; cursor:pointer; transition:all 0.15s; }
.reset-btn:hover { border-color:#1A5F8A; color:#1A5F8A; }
.round-info { font-size:11px; color:#4A6A82; text-align:center; }

/* MEETING ROOM */
.meeting-room { display:flex; flex-direction:column; overflow:hidden; background:#F5F7FA; }
.room-header { padding:1rem 2rem; border-bottom:1px solid #C5D5E4; background:#FFFFFF; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.room-title { font-family:'Arial Black',Arial,sans-serif; font-size:15px; font-weight:900; color:#0D3D5C; }
.room-meta { font-size:11px; color:#4A6A82; margin-top:2px; }
.round-badge { font-size:11px; padding:4px 12px; background:#E8F2FA; border:1px solid #C5D5E4; border-radius:20px; color:#1A5F8A; font-weight:700; }

.chat-feed { flex:1; overflow-y:auto; padding:1.5rem 2rem; display:flex; flex-direction:column; gap:1rem; }
.chat-feed::-webkit-scrollbar { width:5px; }
.chat-feed::-webkit-scrollbar-thumb { background:#C5D5E4; border-radius:3px; }

.empty-room { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; color:#A8C0D6; }
.empty-room .er-icon { font-size:48px; animation:float 3s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.empty-room h3 { font-family:'Arial Black',Arial,sans-serif; font-size:18px; color:#C5D5E4; }
.empty-room p { font-size:13px; color:#C5D5E4; max-width:300px; text-align:center; line-height:1.5; }

.message { display:flex; gap:12px; animation:msgIn 0.4s ease; }
@keyframes msgIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
.msg-avatar { width:42px; height:42px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; margin-top:2px; }
.msg-body { flex:1; }
.msg-header { display:flex; align-items:center; gap:8px; margin-bottom:5px; }
.msg-name { font-size:13px; font-weight:700; color:#0D1B2A; }
.msg-role-tag { font-size:10px; padding:2px 8px; border-radius:4px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; }
.msg-time { font-size:10px; color:#A8C0D6; margin-left:auto; }
.msg-bubble { background:#FFFFFF; border:1px solid #C5D5E4; border-radius:4px 12px 12px 12px; padding:12px 14px; font-size:13.5px; color:#0D1B2A; line-height:1.65; box-shadow:0 1px 4px rgba(0,0,0,0.05); }
.msg-bubble strong { color:#1A5F8A; font-weight:700; }

.typing-msg { display:flex; gap:12px; animation:msgIn 0.3s ease; }
.typing-bubble { background:#FFFFFF; border:1px solid #C5D5E4; border-radius:4px 12px 12px 12px; padding:14px 16px; display:flex; align-items:center; gap:5px; box-shadow:0 1px 4px rgba(0,0,0,0.05); }
.typing-bubble span { width:7px; height:7px; background:#1A5F8A; border-radius:50%; animation:tb 1.2s infinite; opacity:0.4; }
.typing-bubble span:nth-child(2){animation-delay:0.2s;}
.typing-bubble span:nth-child(3){animation-delay:0.4s;}
@keyframes tb { 0%,80%,100%{transform:translateY(0);opacity:0.4} 40%{transform:translateY(-5px);opacity:1} }

.round-divider { display:flex; align-items:center; gap:12px; margin:0.5rem 0; }
.rd-line { flex:1; height:1px; background:#EBF2F8; }
.rd-label { font-size:11px; font-weight:700; color:#1A5F8A; text-transform:uppercase; letter-spacing:1px; padding:3px 12px; background:#E8F2FA; border-radius:20px; border:1px solid #C5D5E4; }

.summary-card { background:#FFFFFF; border:2px solid #1A5F8A; border-radius:12px; padding:1.2rem 1.4rem; margin-top:0.5rem; animation:msgIn 0.5s ease; }
.summary-title { font-family:'Arial Black',Arial,sans-serif; font-size:14px; font-weight:900; color:#0D3D5C; margin-bottom:0.6rem; display:flex; align-items:center; gap:8px; }
.summary-body { font-size:13px; color:#2C4A63; line-height:1.7; }

.toast { position:fixed; bottom:20px; left:50%; transform:translateX(-50%) translateY(10px); background:#0D3D5C; color:#FFFFFF; border-radius:8px; padding:10px 18px; font-size:13px; opacity:0; transition:all 0.3s; pointer-events:none; z-index:999; }
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>
